<style>
:root {
  --bg: #0c0e13;
  --surface: #14171e;
  --surface2: #1a1e28;
  --border: #262b38;
  --text: #e2e4ea;
  --text-dim: #8a8f9e;
  --accent: #6c5ce7;
  --accent2: #00cec9;
  --accent3: #fd79a8;
  --warn: #fdcb6e;
  --success: #00b894;
  --code-bg: #0d1017;
}

* { margin: 0; padding: 0; box-sizing: border-box; }

body {
  background: var(--bg);
  color: var(--text);
  font-family: 'Source Sans 3', sans-serif;
  line-height: 1.7;
  overflow-x: hidden;
}

.container { max-width: 1100px; margin: 0 auto; padding: 0 2rem; }

/* Header */
.hero {
  position: relative;
  padding: 5rem 0 4rem;
  overflow: hidden;
}
.hero::before {
  content: '';
  position: absolute;
  top: -50%;
  left: -20%;
  width: 140%;
  height: 200%;
  background: radial-gradient(ellipse at 30% 50%, rgba(108,92,231,0.08) 0%, transparent 60%),
              radial-gradient(ellipse at 70% 30%, rgba(0,206,201,0.06) 0%, transparent 50%);
  pointer-events: none;
}
.hero h1 {
  font-family: 'DM Serif Display', serif;
  font-size: clamp(2.5rem, 5vw, 4rem);
  letter-spacing: -0.02em;
  line-height: 1.15;
  background: linear-gradient(135deg, var(--text) 40%, var(--accent) 100%);
  -webkit-background-clip: text;
  -webkit-text-fill-color: transparent;
}
.hero .subtitle {
  font-size: 1.15rem;
  color: var(--text-dim);
  margin-top: 1rem;
  max-width: 700px;
  font-weight: 300;
}
.badge {
  display: inline-block;
  background: var(--surface2);
  border: 1px solid var(--border);
  padding: 0.3rem 0.8rem;
  border-radius: 20px;
  font-size: 0.75rem;
  font-family: 'JetBrains Mono', monospace;
  color: var(--accent2);
  margin-bottom: 1.2rem;
}

/* Navigation */
.toc {
  position: sticky;
  top: 0;
  z-index: 100;
  background: rgba(12,14,19,0.85);
  backdrop-filter: blur(16px);
  border-bottom: 1px solid var(--border);
  padding: 0.7rem 0;
  overflow-x: auto;
}
.toc-inner {
  display: flex;
  gap: 0.3rem;
  max-width: 1100px;
  margin: 0 auto;
  padding: 0 2rem;
}
.toc a {
  color: var(--text-dim);
  text-decoration: none;
  font-size: 0.78rem;
  font-family: 'JetBrains Mono', monospace;
  padding: 0.35rem 0.7rem;
  border-radius: 6px;
  white-space: nowrap;
  transition: all 0.2s;
}
.toc a:hover { background: var(--surface2); color: var(--text); }

/* Section */
section { padding: 3.5rem 0 2rem; }
section h2 {
  font-family: 'DM Serif Display', serif;
  font-size: 1.9rem;
  margin-bottom: 0.4rem;
  position: relative;
  display: inline-block;
}
section h2::after {
  content: '';
  position: absolute;
  bottom: -4px;
  left: 0;
  width: 40px;
  height: 3px;
  border-radius: 2px;
  background: var(--accent);
}
.section-lead {
  color: var(--text-dim);
  margin: 1rem 0 2rem;
  font-size: 1.02rem;
  max-width: 750px;
}

/* Architecture Diagram */
.arch-diagram {
  background: var(--surface);
  border: 1px solid var(--border);
  border-radius: 16px;
  padding: 2rem;
  margin: 2rem 0;
  overflow-x: auto;
}
.arch-diagram svg {
  width: 100%;
  max-width: 1000px;
  margin: 0 auto;
  display: block;
}

/* Cards Grid */
.cards { display: grid; grid-template-columns: repeat(auto-fit, minmax(280px, 1fr)); gap: 1.2rem; margin: 1.5rem 0; }
.card {
  background: var(--surface);
  border: 1px solid var(--border);
  border-radius: 14px;
  padding: 1.6rem;
  transition: border-color 0.25s, transform 0.25s;
}
.card:hover { border-color: var(--accent); transform: translateY(-2px); }
.card-icon {
  width: 40px; height: 40px; border-radius: 10px;
  display: flex; align-items: center; justify-content: center;
  font-size: 1.2rem; margin-bottom: 1rem;
}
.card h3 { font-size: 1.05rem; font-weight: 600; margin-bottom: 0.5rem; }
.card p { color: var(--text-dim); font-size: 0.9rem; line-height: 1.6; }

/* Comparison Table */
.table-wrap {
  overflow-x: auto;
  margin: 1.5rem 0;
  border-radius: 14px;
  border: 1px solid var(--border);
}
table {
  width: 100%;
  border-collapse: collapse;
  font-size: 0.88rem;
}
th {
  background: var(--surface2);
  font-family: 'JetBrains Mono', monospace;
  font-size: 0.75rem;
  text-transform: uppercase;
  letter-spacing: 0.08em;
  color: var(--text-dim);
  text-align: left;
  padding: 0.9rem 1.2rem;
  border-bottom: 1px solid var(--border);
  position: sticky;
  top: 0;
}
td {
  padding: 0.85rem 1.2rem;
  border-bottom: 1px solid var(--border);
  vertical-align: top;
  color: var(--text-dim);
}
tr:last-child td { border-bottom: none; }
td:first-child { color: var(--text); font-weight: 600; white-space: nowrap; }
.highlight-devin { color: var(--accent3); }
.highlight-claude { color: var(--accent2); }

/* Flow Steps */
.flow-steps { position: relative; margin: 2rem 0; padding-left: 2rem; }
.flow-steps::before {
  content: '';
  position: absolute;
  left: 11px;
  top: 0;
  bottom: 0;
  width: 2px;
  background: linear-gradient(to bottom, var(--accent), var(--accent2), var(--accent3));
  border-radius: 2px;
}
.step {
  position: relative;
  margin-bottom: 2rem;
  padding-left: 1.6rem;
}
.step::before {
  content: '';
  position: absolute;
  left: -2rem;
  top: 0.45rem;
  width: 12px;
  height: 12px;
  border-radius: 50%;
  border: 2px solid var(--accent);
  background: var(--bg);
}
.step-num {
  font-family: 'JetBrains Mono', monospace;
  font-size: 0.7rem;
  color: var(--accent);
  margin-bottom: 0.3rem;
}
.step h3 { font-size: 1.05rem; margin-bottom: 0.3rem; }
.step p { color: var(--text-dim); font-size: 0.9rem; }

/* Callout Boxes */
.callout {
  border-radius: 12px;
  padding: 1.4rem 1.6rem;
  margin: 1.5rem 0;
  border-left: 3px solid;
  font-size: 0.92rem;
