.callout-warn { background: rgba(253,203,110,0.06); border-color: var(--warn); }
.callout-danger { background: rgba(253,121,168,0.06); border-color: var(--accent3); }
.callout-info { background: rgba(108,92,231,0.06); border-color: var(--accent); }
.callout-success { background: rgba(0,184,148,0.06); border-color: var(--success); }
