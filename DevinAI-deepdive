.callout-danger .callout-title { color: var(--accent3); }
.callout-info .callout-title { color: var(--accent); }
.callout-success .callout-title { color: var(--success); }
.callout p { color: var(--text-dim); line-height: 1.65; }

/* Tags */
.tag-row { display: flex; flex-wrap: wrap; gap: 0.5rem; margin: 1rem 0; }
