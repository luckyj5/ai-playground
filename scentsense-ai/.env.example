# LLM provider abstraction. Choose one: "openai" | "anthropic" | "mock"
LLM_PROVIDER=mock

# Only required when LLM_PROVIDER=openai
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

# Only required when LLM_PROVIDER=anthropic
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-3-5-sonnet-latest

# Optional: path for the lightweight email store (JSON file).
# Defaults to ./data/local/subscribers.json relative to the app root.
SUBSCRIBERS_FILE=

# Optional: public analytics id (e.g. Plausible domain or GA measurement id).
NEXT_PUBLIC_ANALYTICS_DOMAIN=
