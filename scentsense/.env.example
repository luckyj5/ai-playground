# LLM provider abstraction. Choose one: "openai" | "anthropic" | "mock"
LLM_PROVIDER=mock

# Only required when LLM_PROVIDER=openai
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

# Only required when LLM_PROVIDER=anthropic
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-3-5-sonnet-latest

# Affiliate IDs / referrer params (NEXT_PUBLIC_* so they're available at build time).
# Swap these in once the programs are approved.
NEXT_PUBLIC_AMAZON_TAG=scentsense-20
NEXT_PUBLIC_SEPHORA_REF=scentsense
NEXT_PUBLIC_DECANT_REF=scentsense

# Optional: path for the lightweight email store (JSON file) in local dev.
# Defaults to ./data/local/subscribers.json relative to the app root.
# Ignored on Vercel (serverless FS is read-only + ephemeral).
SUBSCRIBERS_FILE=

# Optional: webhook that subscribe events POST to (e.g. Zapier Catch Hook → Google Sheet).
# Strongly recommended on Vercel so emails actually persist somewhere.
SUBSCRIBE_WEBHOOK_URL=

# Optional: public analytics id (e.g. Plausible domain or GA measurement id).
NEXT_PUBLIC_ANALYTICS_DOMAIN=
